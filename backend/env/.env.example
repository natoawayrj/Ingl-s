# Copie para .env e preencha. NUNCA commite o .env real.
#   copy .env.example .env

# ----- MySQL local (Workbench) -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua-senha-do-mysql
DB_NAME=pronuncia

# ----- Auth -----
# gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-um-hex-aleatorio
JWT_EXPIRE_HOURS=720

# ----- Whisper: escolha o provider -----
WHISPER_PROVIDER=whispercpp

# se WHISPER_PROVIDER=openai:
OPENAI_API_KEY=sk-...
OPENAI_WHISPER_MODEL=whisper-1

# se WHISPER_PROVIDER=whispercpp (server local, modo Vulkan na GPU AMD):
WHISPER_URL=http://127.0.0.1:8080/inference

# ----- LLM local (LM Studio, OpenAI-compatible) -----
# Use modelo NAO-thinking (qwen2.5-7b): ~8x mais rapido que gemma-4 thinking.
LLM_URL=http://127.0.0.1:1234/v1/chat/completions
LLM_MODEL=qwen2.5-7b-instruct
LLM_TEMPERATURE=0.3

# Abaixo deste accuracy (0..1) o LLM gera explicacao fonetica detalhada
EXPLAIN_ACCURACY_THRESHOLD=0.8

# ffmpeg: precisa estar no PATH
FFMPEG_BIN=ffmpeg
